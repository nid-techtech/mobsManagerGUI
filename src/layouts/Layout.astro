<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Mobs Manager Editor</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+JP:wght@300;400;500;700&family=Pixelify+Sans:wght@400..700&display=swap" rel="stylesheet">
		<style is:global>
			:root {
				--bg-color: #ffffff;
				--text-color: #1a1a1a;
				--sidebar-bg: #f5f5f5;
				--border-color: #e0e0e0;
				--accent-color: #3b82f6;
				--font-main: 'IBM Plex Sans JP', sans-serif;
				--font-title: 'Pixelify Sans', sans-serif;
			}

			[data-theme='dark'] {
				--bg-color: #1a1a1a;
				--text-color: #f5f5f5;
				--sidebar-bg: #262626;
				--border-color: #404040;
				--accent-color: #60a5fa;
			}

			html, body {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				background-color: var(--bg-color);
				color: var(--text-color);
				font-family: var(--font-main);
				transition: background-color 0.3s, color 0.3s;
			}

			* {
				box-sizing: border-box;
			}
		</style>
	</head>
	<body>
		<slot />
		<script is:inline>
			const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
			document.documentElement.setAttribute('data-theme', theme);
		</script>
	</body>
</html>
